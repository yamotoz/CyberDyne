# =============================================================================
#  CyberDyne — Variáveis de Ambiente / Chaves de API
#  COMO USAR: copie este arquivo para .env e preencha suas chaves
#             cp .env.example .env
#  AVISO: Nunca commite o arquivo .env com chaves reais!
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 1. LLM — ANÁLISE INTELIGENTE DE VULNERABILIDADES
# ─────────────────────────────────────────────────────────────────────────────

# Gemini (Google) — Gera sumário executivo e prompt_recall inteligente
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 2. RECONHECIMENTO E DESCOBERTA (OSINT)
# ─────────────────────────────────────────────────────────────────────────────

# Shodan — Portas abertas e serviços expostos
# Obter em: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# SecurityTrails — Histórico de DNS e subdomínios
# Obter em: https://securitytrails.com/app/account/credentials
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# VirusTotal — Subdomínios indexados
# Obter em: https://www.virustotal.com/gui/user/apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Chaos (ProjectDiscovery) — Base massiva de subdomínios
# Obter em: https://cloud.projectdiscovery.io/
CHAOS_API_KEY=your_chaos_api_key_here

# BinaryEdge — Exposição de ativos na internet
# Obter em: https://app.binaryedge.io/account/api
BINARYEDGE_API_KEY=your_binaryedge_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 3. BUSCA DE VAZAMENTOS E SECRETS (DATA BREACHES)
# ─────────────────────────────────────────────────────────────────────────────

# Have I Been Pwned — Verificar se e-mails foram vazados
# Obter em: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=your_hibp_api_key_here

# Hunter.io — Descobrir padrões de e-mail corporativo
# Obter em: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_api_key_here

# GitHub — GitHub Dorking automático por secrets em commits públicos
# Obter em: https://github.com/settings/tokens (Personal Access Token)
GITHUB_TOKEN=your_github_pat_here

# ─────────────────────────────────────────────────────────────────────────────
# 4. INTELIGÊNCIA DE VULNERABILIDADES
# ─────────────────────────────────────────────────────────────────────────────

# NVD (National Vulnerability Database) — API oficial de CVEs do NIST
# Obter em: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Vulners — Agregador de vulnerabilidades
# Obter em: https://vulners.com/userinfo
VULNERS_API_KEY=your_vulners_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 5. ANÁLISE DE SEGURANÇA
# ─────────────────────────────────────────────────────────────────────────────

# URLScan.io — Analisar o site anonimamente
# Obter em: https://urlscan.io/user/profile/
URLSCAN_API_KEY=your_urlscan_api_key_here

# HackerOne — Verificar se o alvo tem Bug Bounty ativo
# Obter em: https://hackerone.com/settings/api_token/edit
HACKERONE_API_KEY=your_hackerone_api_key_here
HACKERONE_API_SECRET=your_hackerone_api_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# 6. CONFIGURAÇÕES GERAIS DO SCANNER
# ─────────────────────────────────────────────────────────────────────────────

# Delay base entre requisições (segundos) — aumentar para alvos sensíveis
SCAN_DELAY_SECONDS=0.1

# Máximo de threads simultâneas no scanner
SCAN_MAX_THREADS=10

# Timeout padrão para requisições HTTP (segundos)
SCAN_DEFAULT_TIMEOUT=8

# Proxy (opcional) — ex: http://127.0.0.1:8080 para interceptar com Burp
SCAN_PROXY=

# User-Agent personalizado
SCAN_USER_AGENT=Mozilla/5.0 (compatible; CyberDyneWeb/2.0; Security Scanner)
