{
  "info": {
    "name": "Prototype Pollution Payloads",
    "author": "CyberDyne Security",
    "version": "2.0",
    "description": "Prototype Pollution attack payloads targeting Lodash, jQuery, Vue, Axios, and other JavaScript frameworks. 2026 Edition.",
