  "attack_vectors": {
    "service_account_token_exposure": [
      {"path": "/var/run/secrets/kubernetes.io/serviceaccount/token", "description": "SA token path in container"},
      {"path": "/run/secrets/kubernetes.io/serviceaccount/token", "description": "Alternative SA token path"},
      {"path": "/var/secrets/kubernetes.io/serviceaccount/token", "description": "Alt secrets path"}
    ],
    "configmap_exposure": [
      {"path": "/api/v1/namespaces/default/configmaps", "description": "Default configmaps"},
      {"path": "/api/v1/namespaces/kube-system/configmaps", "description": "Kube-system configmaps"}
    ],
    "secret_exposure": [
      {"path": "/api/v1/namespaces/default/secrets", "description": "Default secrets"},
      {"path": "/api/v1/namespaces/kube-public/secrets", "description": "Kube-public secrets"}
    ],
    "credential_dumping": [
      {"payload": "/etc/kubernetes/admin.conf", "description": "Kubeconfig file"},
      {"payload": "/var/lib/minikube/etcd snapshot", "description": "Minikube etcd snapshot"},
      {"payload": "$HOME/.kube/config", "description": "User kubeconfig"}
    ]
  },
