  "detection_indicators": {
    "file_content": ["root:x:", "bin:x:", "[extensions]", "hostname"],
    "oob_indicators": ["HTTP request to attacker", "DNS query", "FTP connection"],
    "error_indicators": ["No such file", "Permission denied", "XML parsing error"]
  },
  "endpoints_patterns": [
    "*.xml", "*\\.soap", "*\\.wsdl", "*\\.xaml",
    "api/xml", "api/soap", "upload", "import",
    "xml", "parse", "feed", "rss", "atom"
  ],
  "content_types": [
    "application/xml", "text/xml", "application/soap+xml",
    "application/x-www-form-urlencoded", "multipart/form-data"
  ]
}
