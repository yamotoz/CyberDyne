{
  "info": {
    "name": "CORS Bypass Payloads",
    "author": "CyberDyne Security",
    "version": "2.0",
    "description": "CORS misconfiguration exploitation payloads - origin bypass, null origin abuse, and subdomain tricks. 2026 Edition.",
    "category": "Web Security",
    "severity": "HIGH",
    "owasp": "A01:2021 - Broken Access Control",
    "references": ["CWE-942", "OWASP CORS Security Cheat Sheet"]
  },
  "philosophy": "CORS bypass is about understanding how origin validation works and finding edge cases. Each payload targets a specific bypass technique.",
  "payloads": {
    "null_origin_bypass": [
      {
        "payload": "null",
        "header": "Origin",
        "description": "Standard null origin - many apps accept this",
        "context": "All requests",
        "indicator": "Access-Control-Allow-Origin: null"
      },
      {
        "payload": "Null",
        "header": "Origin",
        "description": "Capitalized Null",
        "context": "Case-sensitive validation",
        "indicator": "Access-Control-Allow-Origin: Null"
      },
      {
        "payload": "NULL",
        "header": "Origin",
        "description": "All caps NULL",
        "context": "Case-sensitive validation",
        "indicator": "Access-Control-Allow-Origin: NULL"
      },
      {
        "payload": "nul",
        "header": "Origin",
        "description": "Truncated null",
        "context": "Prefix matching",
        "indicator": "Potential bypass"
      }
    ],
    "subdomain_bypass": [
