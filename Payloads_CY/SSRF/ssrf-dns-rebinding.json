{
  "info": {
    "name": "SSRF DNS Rebinding Payloads",
    "author": "CyberDyne Security",
    "version": "2.0",
    "description": "DNS rebinding attack vectors for SSRF bypass. 2026 updated with fast flux, DNS pin, and multi-layer rebinding techniques.",
    "category": "SSRF",
    "severity": "CRITICAL",
    "owasp": "A10:2021 - Server-Side Request Forgery"
  },
  "attack_principle": {
    "explanation": "DNS rebinding tricks the server into making requests to internal resources by controlling DNS TTL and mapping an external domain to an internal IP on the first lookup, then changing it to an external IP or vice versa.",
    "attack_steps": [
      "1. Attacker controls DNS for domain (attacker.com)",
      "2. First DNS lookup returns public IP with short TTL",
      "3. Server makes HTTP request to attacker.com",
      "4. Before second DNS lookup, attacker changes DNS to point to internal IP (169.254.169.254)",
      "5. Server's connection is redirected to internal resource"
    ]
  },
