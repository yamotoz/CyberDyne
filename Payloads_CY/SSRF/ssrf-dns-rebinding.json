  "detection_and_prevention": {
    "indicators_of_vulnerability": [
      "No DNS pinning implemented",
      "Low TTL values accepted",
      "Hostname validation only, not IP validation",
      "No DNS rebinding protection headers"
    ],
    "protection_mechanisms": [
      "DNS pinning (reject DNS changes for connection lifetime)",
      "Validate both hostname AND IP",
      "Use HTTPS with certificate pinning",
      "Block private IP ranges at network level",
      "Set Host header validation"
    ]
  },
  "testing_checklist": [
    "Set up DNS rebinding service",
    "Configure first IP to be public (passes initial checks)",
    "Configure second IP to be internal (169.254.x.x or 10.x.x.x)",
    "Use short TTL (< 5 seconds)",
    "Verify server makes two DNS lookups",
    "Check if server validates hostname or IP",
    "Test with different internal targets"
  ]
