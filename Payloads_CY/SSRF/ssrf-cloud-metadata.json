  "detection_indicators": {
    "gcp": ["google", "project", "zone", "instance-id", "machine-type"],
    "azure": ["vmId", "subscriptionId", "tenantId", "clientId"],
    "digitalocean": ["droplet_id", "hostname", "user-data"],
    "oracle": ["instance-id", "userData"],
