  "info": {
    "name": "SSRF Cloud Metadata Payloads - GCP/Azure/DigitalOcean",
    "author": "CyberDyne Security",
    "version": "2.0",
    "description": "SSRF payloads for cloud metadata - GCP, Azure, DigitalOcean, Oracle, and Kubernetes. 2026 Edition.",
    "category": "Injection",
    "severity": "CRITICAL",
    "owasp": "A10:2021 - Server-Side Request Forgery",
    "references": ["AWS IMDS", "GCP Metadata", "Azure Instance Metadata"]
  },
  "philosophy": "Cloud metadata is gold. Each provider has different endpoints. These payloads are surgical strikes at each cloud platform.",
