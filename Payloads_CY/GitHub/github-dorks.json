{
  "info": {
    "name": "GitHub Dorking Queries",
    "author": "CyberDyne Security",
    "version": "2.0",
    "description": "GitHub search dorks for exposed secrets, credentials, API keys, and sensitive data discovery. 2026 updated.",
    "category": "Recon",
    "severity": "CRITICAL",
    "owasp": "A02:2021 - Cryptographic Failures"
  },
  "dorks": {
    "aws_credentials": [
      {"query": "AKIA[0-9A-Z]{16} repo:github_username", "description": "AWS Access Key ID", "risk": "CRITICAL"},
      {"query": "\"aws_access_key\" \"github.com\"", "description": "AWS access key string", "risk": "CRITICAL"},
      {"query": "\"aws_secret_key\" \"github.com\"", "description": "AWS secret key string", "risk": "CRITICAL"},
      {"query": "filename:.env AWS_ACCESS_KEY", "description": "AWS key in .env", "risk": "CRITICAL"},
      {"query": "path:.env AWS_SECRET", "description": "AWS secret in .env", "risk": "CRITICAL"}
    ],
    "api_keys": [
      {"query": "\"api_key\" \"github.com\"", "description": "Generic API key", "risk": "HIGH"},
      {"query": "filename:credentials.json apiKey", "description": "API key in credentials.json", "risk": "HIGH"},
      {"query": "filename:secrets.yml api_key", "description": "API key in secrets.yml", "risk": "HIGH"},
      {"query": "filename:config.json apiKey", "description": "API key in config.json", "risk": "HIGH"},
      {"query": "extension:json \"api_key\"", "description": "API key in JSON", "risk": "HIGH"},
      {"query": "extension:yaml \"api_key\"", "description": "API key in YAML", "risk": "HIGH"},
      {"query": "extension:yml \"api_key\"", "description": "API key in YML", "risk": "HIGH"},
      {"query": "extension:ini \"api_key\"", "description": "API key in INI", "risk": "HIGH"},
      {"query": "extension:toml \"api_key\"", "description": "API key in TOML", "risk": "HIGH"}
    ],
    "google_api": [
